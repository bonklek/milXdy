{
  "manifest_version": 3,
  "name": "milXdy",
  "version": "0.2.1",
  "description": "An integrated X/Twitter experience enhancer by consolidating multiple browser extensions.",
  "permissions": ["alarms", "contextMenus", "storage", "unlimitedStorage", "notifications", "cookies", "tabs"],
  "host_permissions": [
    "https://api.github.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://abs.twimg.com/*",
    "https://pbs.twimg.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://remilia.wiki/*",
    "https://wiki.remilia.org/*",
    "https://api.remistats.net/*",
    "https://pfp.remilia.net/*",
    "https://ethereum.publicnode.com/*",
    "https://miladymaker.net/banners/nft/*",
    "https://www.remilia.net/*",
    "wss://www.remilia.net/*",
    "https://boards.miladychan.org/*",
    "wss://boards.miladychan.org/*",
    "https://musicbrainz.org/*",
    "https://api.acoustid.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://wiki.remilia.org/*", "https://remilia.wiki/*"],
      "js": ["wikiFrame.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "brand/*",
        "icons/*",
        "ocr.html",
        "ocrHost.js",
        "ocr/*",
        "ocr/core/*",
        "ocr/lang/*",
        "remistats/*",
        "remilia-fonts/*",
        "post-reading/*",
        "beetol/*",
        "reminetChat/*",
        "miladychanSpotlight/*",
        "music/*",
        "miladymaxxer/*",
        "features/*.js",
        "features/*.wasm",
        "milady-logo.png",
        "worker.js",
        "ort/*",
        "generated/*",
        "models/*"
      ],
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://remilia.wiki/*", "https://wiki.remilia.org/*"]
    }
  ],
  "options_page": "popup.html",
  "action": {
    "default_title": "milXdy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
