{
  "name": "milxdy",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "An integrated X/Twitter experience enhancer by consolidating multiple browser extensions.",
  "license": "VPL",
  "scripts": {
    "build": "npm run build:chromium",
    "build:chromium": "node scripts/build.mjs --target=chromium",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "build:all": "npm run build:chromium && npm run build:firefox",
    "dev": "node scripts/build.mjs --target=chromium --watch",
    "typecheck": "tsc --noEmit",
    "lint:firefox": "web-ext lint --source-dir dist/firefox"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "onnxruntime-web": "^1.24.3",
    "solid-js": "^1.9.12",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "web-ext": "^8.4.0"
  }
}
