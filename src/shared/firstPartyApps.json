  {
    "id": "remistats",
    "name": "RemiStats",
    "version": "0.1.5",
    "description": "Adds RemiStats profile and user metrics to X surfaces.",
    "entryName": "features/remistats",
    "entryPoint": "src/entries/remistatsContent.ts",
    "contentEntry": "features/remistats.js",
    "defaultEnabled": true,
    "storageKeys": { "sync": ["milxdy.remistats.enabled", "milxdy.remistats.pokeAutoLike"] },
    "surfaces": ["tweet", "userCell", "profile", "route"],
    "cost": { "startup": "moderate", "perSurface": "moderate", "network": "batched", "worker": "none", "domWrite": "moderate" },
    "loadTriggers": ["surface", "idle"],
    "hub": {
      "category": "social",
      "shortDescription": "Show RemiStats profile, post, and poke context on X.",
      "rail": { "supported": false, "defaultPinned": false },
      "presets": ["balanced", "full"],
      "permissionNotes": ["Fetches RemiStats and RemiliaNET profile data for visible handles."],
      "dataNotes": ["Sends X handles to the RemiStats API when badge data is needed and may resolve verified PFP owners through Ethereum RPC."],
      "remoteServices": ["api.remistats.net", "pfp.remilia.net", "www.remilia.net", "ethereum.publicnode.com"],
      "localStorageNotes": ["Stores badge, poke cooldown, and theme state."],
      "privacyLabels": ["remote-api"]
    },
    "background": { "messageTypes": ["remistats:getUser", "reminetIdentity:getProfile"] },
    "permissions": { "hosts": ["https://api.remistats.net/*", "https://pfp.remilia.net/*", "https://www.remilia.net/*", "https://ethereum.publicnode.com/*"] },
    "css": [{ "id": "milxdy-remistats-styles", "path": "remistats/remistats.css", "source": "src/features/remistats/remistats.css", "targetDir": "remistats", "target": "remistats.css" }],
    "assets": ["remistats"]
  },
